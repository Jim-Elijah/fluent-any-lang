{
  "name": "fluent-any-lang",
  "version": "0.2.0",
  "private": true,
  "description": "Listening and speaking practice web app for any language",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "lit-localize build && tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css,html}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "pnpm run build && playwright test",
    "localize:extract": "lit-localize extract",
    "localize:build": "lit-localize build",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -o CHANGELOG.md",
    "changelog:first": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -o CHANGELOG.md -r 0",
    "version": "pnpm run changelog && git add CHANGELOG.md",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "language-learning",
    "lit",
    "indexeddb"
  ],
  "homepage": "https://fal.jimelijah.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jim-Elijah/fluent-any-lang.git"
  },
  "bugs": {
    "url": "https://github.com/Jim-Elijah/fluent-any-lang/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@lit/localize": "^0.12.2",
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "lit": "^3.3.3",
    "lit-element-router": "^2.0.3",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@lit/localize-tools": "^0.8.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "conventional-changelog": "^8.1.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0"
}
